      "note": "Cells that cannot produce realistic cases -- documented with reasoning",
      "cells": [
        {
          "cell": "illegitimate_authority:club",
          "reason": "Clubs are low-stakes voluntary associations; legitimacy questions are trivial -- just leave."
        },
        {
          "cell": "illegitimate_authority:private_property_owner",
          "reason": "Property owners have narrow authority; legitimacy is not a meaningful category."
        },
        {
          "cell": "illegitimate_authority:contractual_counterparty",
          "reason": "Contracts derive authority from mutual agreement; illegitimacy collapses into 'void contract' which is a legal question, not an evasion scenario."
        },
        {
          "cell": "illegitimate_authority:creditor_insurer",
          "reason": "Creditor authority derives from contract; illegitimacy is a legal claim, not an evasion scenario."
        },
        {
          "cell": "illegitimate_authority:housing_association",
          "reason": "HOA authority derives from CC&Rs signed at purchase; legitimacy challenges are legal, not evasion."
        },
        {
          "cell": "illegitimate_authority:landlord",
          "reason": "Landlord authority derives from lease; illegitimacy is a lease validity question."
        },
        {
          "cell": "illegitimate_authority:union",
          "reason": "Union authority is typically democratic; illegitimacy claims are intra-organizational, not evasion scenarios."
        }
